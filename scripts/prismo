#!/usr/bin/env bash
# prismo — Prismo project automation
# Usage: prismo <command> [args]
set -euo pipefail

VM_HOST="${VM_HOST:-localhost}"
CONTEXT_API="${CONTEXT_API:-http://${VM_HOST}:8000}"
MCP_URL="${MCP_URL:-http://${VM_HOST}:8001/mcp}"
PRISMO_REPO="${PRISMO_REPO:-git@github.com:EthanPlusPlus/prismo.git}"

# ── Output helpers ────────────────────────────────────────────────────────────

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; BOLD='\033[1m'; NC='\033[0m'

step()    { echo -e "\n${BLUE}${BOLD}==> $*${NC}"; }
ok()      { echo -e "  ${GREEN}✓ $*${NC}"; }
warn()    { echo -e "  ${YELLOW}! $*${NC}"; }
info()    { echo -e "    $*"; }
die()     { echo -e "  ${RED}✗ $*${NC}" >&2; exit 1; }
confirm() { local _a; echo -en "${YELLOW}  ? $* [y/N] ${NC}"; read -r _a; [[ "$_a" =~ ^[Yy]$ ]]; }

# ── Shared checks ─────────────────────────────────────────────────────────────

check_prereqs() {
  step "Checking prerequisites"
  command -v git   >/dev/null 2>&1 || die "git not found"
  ok "git"
  command -v curl  >/dev/null 2>&1 || die "curl not found"
  ok "curl"
  command -v claude >/dev/null 2>&1 || die "Claude Code not found — install from https://claude.ai/code"
  ok "Claude Code"
}

check_vm() {
  step "Checking VM connectivity"
  curl -sf --max-time 5 "${CONTEXT_API}/health" >/dev/null 2>&1 \
    || die "Cannot reach context-server at ${CONTEXT_API} — is Tailscale connected?"
  ok "context-server reachable"
}

# ── Worktree hook install ─────────────────────────────────────────────────────

install_worktree_hook() {
  local project_git="$1"   # e.g. ~/projects/foo/.git
  local worktree_name="$2" # e.g. foo (matches dir name under ~/canon/)
  local hook_script="$3"

  local wt_git="${project_git}/worktrees/${worktree_name}"
  [[ -d "$wt_git" ]] || die "Worktree git dir not found: $wt_git"

  mkdir -p "${wt_git}/hooks"
  printf '%s\n' "$hook_script" > "${wt_git}/hooks/post-merge"
  chmod +x "${wt_git}/hooks/post-merge"
  git -C "${HOME}/canon/${worktree_name}" config --worktree core.hooksPath "${wt_git}/hooks"
  ok "Re-index hook installed for ${worktree_name} worktree"
}

# ── MCP registration ──────────────────────────────────────────────────────────

add_mcp() {
  local dir="$1"
  local label
  label=$(basename "$dir")
  info "Adding MCP for $label ($dir)"
  ( cd "$dir" && claude mcp add context-server --transport http "$MCP_URL" 2>&1 ) \
    && ok "MCP registered for $label" \
    || warn "MCP add failed for $label — run manually:\n    cd $dir && claude mcp add context-server --transport http $MCP_URL"
}

# ── new-machine ───────────────────────────────────────────────────────────────

_setup_repo() {
  local name="$1"
  local repo_url="$2"
  local sparse_dirs="$3"   # space-separated, empty = no sparse checkout
  local docs_branch="$4"   # branch the docs worktree tracks

  local project_dir="${HOME}/projects/${name}"
  local canon_dir="${HOME}/canon/${name}"

  step "Setting up ${name}"

  # Clone
  if [[ -d "${project_dir}/.git" ]]; then
    ok "${name} already cloned — skipping"
  else
    git clone "$repo_url" "$project_dir"
    ok "Cloned → $project_dir"
  fi

  # Sparse checkout (code only)
  if [[ -n "$sparse_dirs" ]]; then
    git -C "$project_dir" sparse-checkout init --cone
    # shellcheck disable=SC2086
    git -C "$project_dir" sparse-checkout set $sparse_dirs
    ok "Sparse checkout: $sparse_dirs"
  fi

  # Install scripts/install-hooks.sh if it exists
  if [[ -f "${project_dir}/scripts/install-hooks.sh" ]]; then
    (cd "$project_dir" && bash scripts/install-hooks.sh)
    ok "Code repo hook installed"
  fi

  # Docs worktree
  if [[ -d "$canon_dir" ]]; then
    ok "Docs worktree already at $canon_dir"
  else
    git -C "$project_dir" config extensions.worktreeConfig true
    git -C "$project_dir" worktree add "$canon_dir" "$docs_branch"
    git -C "$canon_dir" sparse-checkout init --cone
    git -C "$canon_dir" sparse-checkout set docs
    ok "Docs worktree → $canon_dir (branch: $docs_branch)"
  fi

  # Worktree re-index hook
  local hook_body
  hook_body="$(printf '#!/bin/bash\ncurl -s -X POST %s/index' "$CONTEXT_API")"
  install_worktree_hook "${project_dir}/.git" "$name" "$hook_body"

  # MCP
  add_mcp "$project_dir"
  add_mcp "$canon_dir"
}

cmd_new_machine() {
  echo -e "\n${BOLD}Prismo — New Machine Setup${NC}"
  echo "Homelab is already cloned. This sets up the rest."
  echo ""

  check_prereqs
  check_vm

  step "Creating directory structure"
  mkdir -p "${HOME}/projects" "${HOME}/canon"
  ok "~/projects and ~/canon ready"

  # MCP for prismo itself
  step "MCP for prismo"
  add_mcp "${HOME}/canon/prismo"

  # Known projects
  echo ""
  if confirm "Set up context-server?"; then
    _setup_repo \
      "context-server" \
      "git@github.com:EthanPlusPlus/context-server.git" \
      "api chroma_store context_mcp indexers" \
      "context-server"
  fi

  echo ""
  if confirm "Set up devcamp?"; then
    _setup_repo \
      "devcamp" \
      "git@github.com:EthanPlusPlus/devcamp.git" \
      "" \
      "master"
  fi

  # Memory
  step "Shared memory"
  local key
  key=$(echo "${HOME}/canon/prismo" | sed 's|^/||; s|/|-|g')
  local mem_dir="${HOME}/.claude/projects/${key}/memory"
  mkdir -p "$mem_dir"

  local shared=("system.md" "workflow.md" "mcp.md" "shorthands.md")
  for f in "${shared[@]}"; do
    local src="${HOME}/canon/prismo/docs/memory/${f}"
    local dst="${mem_dir}/${f}"
    [[ -e "$dst" && ! -L "$dst" ]] && rm "$dst"
    [[ ! -L "$dst" ]] && ln -s "$src" "$dst"
    ok "Shared: $f"
  done
  info "Shared memory updates automatically on git pull."

  echo ""
  if confirm "Copy personal memory from VM? (MEMORY.md, feedback files)"; then
    local vm_mem="ethan@${VM_HOST}:~/.claude/projects/-home-ethan/memory/"
    for pf in MEMORY.md feedback_mcp_dual_query.md; do
      scp "${vm_mem}${pf}" "${mem_dir}/${pf}" 2>/dev/null \
        && ok "Synced: $pf" \
        || warn "Not found: $pf (skip if this is the source VM)"
    done
  fi

  echo ""
  echo -e "${GREEN}${BOLD}✓ Machine setup complete.${NC}"
  echo ""
  echo "  Start a session:  cd ~/canon/prismo && claude"
  echo "  Check everything: prismo status"
}

# ── new-project ───────────────────────────────────────────────────────────────

cmd_new_project() {
  local name="${1:-}"
  local repo_url="${2:-}"
  [[ -n "$name" && -n "$repo_url" ]] || die "Usage: prismo new-project <name> <repo-url>"

  echo -e "\n${BOLD}Prismo — New Project: ${name}${NC}\n"

  check_prereqs
  check_vm

  local project_dir="${HOME}/projects/${name}"
  local canon_dir="${HOME}/canon/${name}"

  # 1. Clone
  step "Clone"
  if [[ -d "${project_dir}/.git" ]]; then
    ok "Already cloned at $project_dir"
  else
    git clone "$repo_url" "$project_dir"
    ok "Cloned → $project_dir"
  fi

  # 2. CLAUDE.md (on master/main, before branching)
  step "CLAUDE.md"
  local default_branch
  default_branch=$(git -C "$project_dir" symbolic-ref --short HEAD 2>/dev/null || echo "master")

  if [[ -f "${project_dir}/CLAUDE.md" ]]; then
    ok "CLAUDE.md already exists"
  else
    cat > "${project_dir}/CLAUDE.md" << EOF
# ${name}

Brief description of what this project is.

## MCP

Always retrieve context via MCP before reasoning or planning.

To add the MCP server (run from this repo directory):

    claude mcp add context-server --transport http \\
      ${MCP_URL}

## Workflow

1. Retrieve context from MCP
2. Check docs/context/ — progress.md, recent-changes.md, constraints.md
3. Propose a plan — wait for approval before touching anything
4. Execute the approved plan
5. Update docs/context/ and any affected docs
6. Re-index: curl -X POST ${CONTEXT_API}/index
7. Commit and push
EOF
    git -C "$project_dir" add CLAUDE.md
    git -C "$project_dir" commit -m "add CLAUDE.md session bootstrap"
    git -C "$project_dir" push
    ok "CLAUDE.md created and pushed"
  fi

  # 3. Sparse checkout (exclude docs/)
  step "Sparse checkout"
  local top_dirs
  top_dirs=$(git -C "$project_dir" ls-tree --name-only HEAD 2>/dev/null | grep -v '^docs$' | tr '\n' ' ' || true)
  if [[ -n "$top_dirs" ]]; then
    info "Top-level dirs (excluding docs/): $top_dirs"
    if confirm "Apply sparse checkout to exclude docs/ from ~/projects/${name}?"; then
      git -C "$project_dir" sparse-checkout init --cone
      # shellcheck disable=SC2086
      git -C "$project_dir" sparse-checkout set $top_dirs
      ok "Sparse checkout applied"
    fi
  else
    warn "Repo is empty — sparse checkout skipped (configure later once dirs exist)"
  fi

  # 4. Docs branch + scaffold
  step "Docs branch"
  local has_docs
  has_docs=$(git -C "$project_dir" ls-remote --heads origin docs 2>/dev/null || echo "")

  if [[ -n "$has_docs" ]]; then
    ok "docs branch already exists on origin"
    git -C "$project_dir" fetch origin docs
  else
    info "Creating docs branch from $default_branch"
    git -C "$project_dir" checkout -b docs

    mkdir -p "${project_dir}/docs/"{decisions,runbooks,architecture,context,proposed-ideas}

    cat > "${project_dir}/docs/context/progress.md" << 'DOCEOF'
# Progress

## Working On

_(add a one-liner when you start a session — clear it when you're done)_

## In Progress

_(nothing currently in progress)_

## Next

_(see proposed-ideas/ for upcoming directions)_

## Done

_(nothing yet)_
DOCEOF

    cat > "${project_dir}/docs/context/recent-changes.md" << 'DOCEOF'
# Recent Changes

Rolling log of meaningful system changes. Keep last ~10 entries.

---

_(no changes yet)_
DOCEOF

    cat > "${project_dir}/docs/context/constraints.md" << 'DOCEOF'
# Constraints

Active limitations that materially affect design or system behavior.

---

_(none documented yet)_
DOCEOF

    cat > "${project_dir}/docs/context/open-questions.md" << 'DOCEOF'
# Open Questions

_(none yet)_
DOCEOF

    # Copy STRUCTURE.md template from prismo
    local tmpl="${HOME}/canon/prismo/docs/STRUCTURE.md"
    if [[ -f "$tmpl" ]]; then
      cp "$tmpl" "${project_dir}/docs/STRUCTURE.md"
      warn "docs/STRUCTURE.md copied from prismo template — update it for this project"
    fi

    git -C "$project_dir" add -A
    git -C "$project_dir" commit -m "bootstrap docs structure"
    git -C "$project_dir" push -u origin docs
    ok "docs branch created and pushed"

    # Merge back so master has the full picture (CLAUDE.md already there)
    git -C "$project_dir" checkout "$default_branch"
  fi

  # 5. Docs worktree
  step "Docs worktree at ~/canon/${name}"
  if [[ -d "$canon_dir" ]]; then
    ok "Already exists"
  else
    git -C "$project_dir" config extensions.worktreeConfig true
    git -C "$project_dir" worktree add "$canon_dir" docs
    git -C "$canon_dir" sparse-checkout init --cone
    git -C "$canon_dir" sparse-checkout set docs
    ok "Worktree created → $canon_dir"
  fi

  # 6. Worktree re-index hook
  step "Re-index hook"
  local hook_body
  hook_body="$(printf '#!/bin/bash\ncurl -s -X POST %s/index' "$CONTEXT_API")"
  install_worktree_hook "${project_dir}/.git" "$name" "$hook_body"

  # 7. Initial index
  step "Initial index"
  info "Indexing docs..."
  curl -sf -X POST "${CONTEXT_API}/index" >/dev/null && ok "Docs indexed"
  info "Indexing code..."
  curl -sf -X POST "${CONTEXT_API}/index/code?project=${name}" >/dev/null \
    && ok "Code indexed" \
    || warn "Code index skipped (empty repo is fine — re-run: prismo index ${name})"

  # 8. MCP
  step "MCP registration"
  add_mcp "$project_dir"
  add_mcp "$canon_dir"

  # 9. Homelab reminder
  echo ""
  warn "Update prismo docs before next session:"
  info "  ~/canon/prismo/docs/context/     — add ${name} to service inventory"
  info "  ~/canon/prismo/docs/runbooks/new-machine-setup.md — add sparse-checkout dirs"
  info "Then: prismo index && cd ~/canon/prismo && git add -A && git commit && git push"

  echo ""
  echo -e "${GREEN}${BOLD}✓ Project '${name}' is ready.${NC}"
  echo ""
  echo "  Code:    ~/projects/${name}"
  echo "  Docs:    ~/canon/${name}/docs/"
  echo ""
  echo "  Start a session:  cd ~/projects/${name} && claude"
}

# ── index ─────────────────────────────────────────────────────────────────────

cmd_index() {
  local project="${1:-}"
  check_vm
  if [[ -n "$project" ]]; then
    step "Indexing code: $project"
    curl -sf -X POST "${CONTEXT_API}/index/code?project=${project}" \
      | python3 -m json.tool 2>/dev/null \
      || curl -f -X POST "${CONTEXT_API}/index/code?project=${project}"
  else
    step "Indexing all docs"
    curl -sf -X POST "${CONTEXT_API}/index" \
      | python3 -m json.tool 2>/dev/null \
      || curl -f -X POST "${CONTEXT_API}/index"
  fi
}

# ── status ────────────────────────────────────────────────────────────────────

cmd_status() {
  echo -e "\n${BOLD}Prismo Status${NC}\n"

  echo -e "${BOLD}VM / context-server${NC}"
  if curl -sf --max-time 5 "${CONTEXT_API}/health" 2>/dev/null | grep -q '"ok"'; then
    local count
    count=$(curl -sf --max-time 5 "${CONTEXT_API}/health" | python3 -c "import sys,json; print(json.load(sys.stdin).get('docs_indexed','?'))" 2>/dev/null || echo "?")
    ok "context-server  ${CONTEXT_API}  (${count} docs indexed)"
  else
    warn "context-server unreachable — ${CONTEXT_API}"
    info "Is Tailscale running? Try: tailscale status"
  fi

  echo ""
  echo -e "${BOLD}Git hooks${NC}"
  local repos=(
    "${HOME}/canon/prismo"
    "${HOME}/projects/context-server"
    "${HOME}/canon/context-server"
    "${HOME}/projects/devcamp"
  )
  for repo in "${repos[@]}"; do
    if [[ ! -d "$repo" ]]; then
      info "(not cloned)  $repo"
      continue
    fi
    local git_dir hook
    git_dir=$(git -C "$repo" rev-parse --git-dir 2>/dev/null || echo "")
    [[ -n "$git_dir" ]] || { info "(not a git repo)  $repo"; continue; }
    hook="${git_dir}/hooks/post-merge"
    if [[ -x "$hook" ]]; then
      ok "$repo"
    else
      warn "$repo  — post-merge hook missing"
      info "    Fix: cd $repo && bash scripts/install-hooks.sh"
    fi
  done

  echo ""
  echo -e "${BOLD}Canon — last commit${NC}"
  local canon_repos=(
    "${HOME}/canon/prismo"
    "${HOME}/canon/context-server"
  )
  for repo in "${canon_repos[@]}"; do
    if [[ ! -d "$repo" ]]; then
      info "(not cloned)  $repo"
      continue
    fi
    local log
    log=$(git -C "$repo" log -1 --format="%C(yellow)%h%Creset  %an  %ar  —  %s" 2>/dev/null || echo "(no commits)")
    echo -e "  ${BOLD}$(basename "$repo")${NC}  $log"
  done

  echo ""
  echo -e "${BOLD}Memory${NC}"
  local key
  key=$(echo "$(pwd)" | sed 's|^/||; s|/|-|g')
  local mem="${HOME}/.claude/projects/${key}/memory"
  if [[ -d "$mem" ]]; then
    local symlink_count
    symlink_count=$(find "$mem" -maxdepth 1 -type l 2>/dev/null | wc -l)
    ok "Memory found for launch dir: $(pwd)  (${symlink_count} shared symlinks)"
  else
    warn "No memory at $mem"
    info "Launch from ~/canon/prismo for memory to load, or run: prismo new-machine"
  fi
}

# ── session (Decision 014 + 016 — workflow-state-service) ─────────────────────

SESSION_FILE="${HOME}/.prismo-active-session"

_infer_project() {
  local cwd="${1:-$(pwd)}"
  if [[ "$cwd" == "${HOME}/canon/"* ]]; then
    echo "$cwd" | sed "s|${HOME}/canon/||" | cut -d/ -f1
  elif [[ "$cwd" == "${HOME}/projects/"* ]]; then
    echo "$cwd" | sed "s|${HOME}/projects/||" | cut -d/ -f1
  else
    echo "prismo"
  fi
}

_session_is_active() {
  local sid="$1"
  [[ -n "$sid" ]] || return 1
  local status
  status=$(curl -sf --max-time 3 "${CONTEXT_API}/workflow/session/${sid}" 2>/dev/null \
    | python3 -c "import sys,json; print(json.load(sys.stdin).get('session',{}).get('status',''))" 2>/dev/null)
  [[ "$status" == "active" ]]
}

cmd_session() {
  local sub="${1:-current}"
  shift 2>/dev/null || true

  case "$sub" in
    start)
      local project="${1:-$(_infer_project)}"
      local contributor="${2:-ethan}"
      check_vm
      local resp
      resp=$(curl -sf -X POST "${CONTEXT_API}/workflow/session/start" \
        -H 'Content-Type: application/json' \
        -d "{\"contributor_id\":\"${contributor}\",\"project\":\"${project}\"}")
      local sid
      sid=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['session_id'])")
      echo "$sid" > "$SESSION_FILE"
      ok "Session started: $sid (project=$project, contributor=$contributor)"
      ;;
    end)
      [[ -f "$SESSION_FILE" ]] || die "No active session file at $SESSION_FILE"
      local sid
      sid=$(cat "$SESSION_FILE")
      check_vm

      # Warn on uncommitted changes in canon repos before closing.
      local dirty_repos=()
      for repo in "${HOME}/canon/prismo" "${HOME}/projects/context-server" "${HOME}/projects/prismo-ui"; do
        [[ -d "$repo/.git" || -f "$repo/.git" ]] || continue
        if ! git -C "$repo" diff --quiet 2>/dev/null || ! git -C "$repo" diff --cached --quiet 2>/dev/null; then
          dirty_repos+=("$repo")
        fi
      done
      if [[ ${#dirty_repos[@]} -gt 0 ]]; then
        warn "Uncommitted changes in: ${dirty_repos[*]}"
        warn "Consider committing before ending the session."
      fi

      # Write session summary to operational_events before ending.
      # Derives summary from git commits made since session start (objective record of
      # work done), falling back to current_focus if no commits found. This avoids the
      # session summary being just the opening greeting (the focus seed problem).
      local ctx_resp focus_text session_started_at captures_count summary_text git_summary
      ctx_resp=$(curl -sf --max-time 5 "${CONTEXT_API}/workflow/session/${sid}" 2>/dev/null)
      focus_text=$(echo "$ctx_resp" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('context', {}).get('current_focus', '') or '')
except Exception:
    print('')" 2>/dev/null)
      session_started_at=$(echo "$ctx_resp" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get('session', {}).get('started_at', '') or '')
except Exception:
    print('')" 2>/dev/null)
      captures_count=$(curl -sf --max-time 5 "${CONTEXT_API}/workflow/captures?status=pending-review" 2>/dev/null \
        | python3 -c "import sys,json; print(len(json.load(sys.stdin).get('captures',[])))" 2>/dev/null || echo "0")

      # Collect commit subjects from all canon repos since session start.
      git_summary=""
      if [[ -n "$session_started_at" ]]; then
        local canon_repos=("${HOME}/canon/prismo" "${HOME}/projects/context-server")
        local all_commits=()
        for repo in "${canon_repos[@]}"; do
          [[ -d "$repo/.git" || -f "$repo/.git" ]] || continue
          local commits
          commits=$(git -C "$repo" log --since="$session_started_at" --format="%s" 2>/dev/null \
            | grep -v "^Co-Authored\|^Merge" | head -5 || true)
          if [[ -n "$commits" ]]; then
            while IFS= read -r line; do
              [[ -n "$line" ]] && all_commits+=("$line")
            done <<< "$commits"
          fi
        done
        if [[ ${#all_commits[@]} -gt 0 ]]; then
          git_summary=$(printf '%s; ' "${all_commits[@]}" | sed 's/; $//')
        fi
      fi

      summary_text="${git_summary:-${focus_text:-session ended}}"
      local _tmp_summary
      _tmp_summary=$(mktemp)
      python3 -c "
import json, sys
print(json.dumps({'summary': sys.argv[1], 'captures_count': int(sys.argv[2])}))
" "$summary_text" "${captures_count:-0}" > "$_tmp_summary"
      curl -sf --max-time 5 -X POST "${CONTEXT_API}/workflow/session/${sid}/summarize" \
        -H 'Content-Type: application/json' \
        -d @"$_tmp_summary" >/dev/null 2>&1 || true
      rm -f "$_tmp_summary"

      curl -sf -X POST "${CONTEXT_API}/workflow/session/${sid}/end" >/dev/null \
        && ok "Session ended: $sid" \
        || warn "Server-side end failed (session may already be ended)"
      rm -f "$SESSION_FILE"
      ;;
    current|status)
      if [[ -f "$SESSION_FILE" ]]; then
        local sid
        sid=$(cat "$SESSION_FILE")
        check_vm
        local info
        info=$(curl -sf "${CONTEXT_API}/workflow/session/${sid}" 2>/dev/null)
        if [[ -n "$info" ]]; then
          echo "$info" | python3 -m json.tool
        else
          warn "Session id $sid not found on server"
        fi
      else
        warn "No active session ($SESSION_FILE missing)"
        info "Start one: prismo session start [project] [contributor]"
      fi
      ;;
    ensure)
      # Idempotent: starts a session if none exists or stored session is no longer active.
      # On NEW session creation, also:
      #  - reads stdin (UserPromptSubmit hook passes prompt) to seed current_focus
      #  - fetches ContextBundle via get_context and emits it as hydrated context
      #  - closes any orphan active sessions for same project+contributor
      # On EXISTING session: silent.
      # Used by UserPromptSubmit hook. Never blocks prompts on service failure.
      local project="${1:-$(_infer_project)}"
      local contributor="${2:-ethan}"
      local sid=""
      [[ -f "$SESSION_FILE" ]] && sid=$(cat "$SESSION_FILE" 2>/dev/null)
      if _session_is_active "$sid"; then
        return 0
      fi

      # Read stdin if available (hook passes prompt); use as focus seed.
      # Claude Code's UserPromptSubmit hook sends a JSON envelope on stdin
      # ({session_id, transcript_path, cwd, prompt, ...}). Parse out .prompt;
      # fall back to raw text for non-Claude invocations (e.g. plain echo).
      local focus_seed=""
      if [[ ! -t 0 ]]; then
        local raw
        raw=$(cat 2>/dev/null)
        if [[ -n "$raw" ]]; then
          focus_seed=$(printf '%s' "$raw" | python3 -c "
import sys, json
data = sys.stdin.read()
try:
    obj = json.loads(data)
    text = obj.get('prompt') or obj.get('user_prompt') or ''
except Exception:
    text = data
text = text.strip()
# Skip system-injected content (task notifications, XML tags, etc.)
if text.startswith('<'):
    text = ''
text = ' '.join(text.split())
print(text[:200])
" 2>/dev/null)
        fi
      fi

      # Close orphan active sessions for this contributor+project
      curl -sf --max-time 3 "${CONTEXT_API}/workflow/state/${project}" 2>/dev/null \
        | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    for s in d.get('active_sessions', []):
        if s.get('contributor_id') == '${contributor}':
            print(s['id'])
except Exception:
    pass" 2>/dev/null | while read -r orphan_id; do
        [[ -n "$orphan_id" ]] && curl -sf --max-time 3 -X POST "${CONTEXT_API}/workflow/session/${orphan_id}/end" >/dev/null 2>&1
      done

      # Start new session
      local resp
      resp=$(curl -sf --max-time 5 -X POST "${CONTEXT_API}/workflow/session/start" \
        -H 'Content-Type: application/json' \
        -d "{\"contributor_id\":\"${contributor}\",\"project\":\"${project}\"}" 2>/dev/null)
      [[ -n "$resp" ]] || return 0
      sid=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['session_id'])" 2>/dev/null)
      [[ -n "$sid" ]] || return 0
      echo "$sid" > "$SESSION_FILE"

      # Seed focus from prompt if available
      if [[ -n "$focus_seed" ]]; then
        curl -sf --max-time 3 -X PATCH "${CONTEXT_API}/workflow/context/${sid}" \
          -H 'Content-Type: application/json' \
          -d "$(python3 -c "import json; print(json.dumps({'current_focus': '''${focus_seed//\'/\\\'}'''}))")" \
          >/dev/null 2>&1
      fi

      # Fetch ContextBundle, unacknowledged stale items, and last session summary
      local bundle stale captures last_session
      bundle=$(curl -sf --max-time 10 "${CONTEXT_API}/context?project=${project}&contributor=${contributor}&depth=standard" 2>/dev/null)
      stale=$(curl -sf --max-time 5 "${CONTEXT_API}/stale-items?project=${project}" 2>/dev/null)
      captures=$(curl -sf --max-time 5 "${CONTEXT_API}/workflow/captures?project=${project}&status=pending-review" 2>/dev/null)
      last_session=$(curl -sf --max-time 5 "${CONTEXT_API}/workflow/contributor/${contributor}/last-session?project=${project}" 2>/dev/null)
      echo ""
      echo "[PRISMO SESSION] session=${sid} project=${project} contributor=${contributor}"
      if [[ -n "$stale" ]]; then
        local stale_count
        stale_count=$(echo "$stale" | python3 -c "import sys,json; print(json.load(sys.stdin).get('stale_count',0))" 2>/dev/null)
        if [[ "${stale_count:-0}" -gt 0 ]]; then
          echo "[V2 LIFECYCLE] ${stale_count} unacknowledged stale items — review via: prismo stale"
          echo "$stale" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for it in d.get('items', [])[:3]:
    md = it.get('metadata', {})
    print(f\"  [{it.get('rule')}] {md.get('path','?')} (updated {md.get('updated_at','?')})\")" 2>/dev/null
        fi
      fi
      if [[ -n "$captures" ]]; then
        echo "$captures" | python3 -c "
import sys, json
d = json.load(sys.stdin)
caps = d.get('captures', [])
if caps:
    print(f'[V2 CAPTURES] {len(caps)} pending review — triage via: prismo capture list')
    for c in caps[:3]:
        text = c.get('text', '').replace(chr(10), ' ')[:120]
        print(f\"  [{c['id']}] {text}\")" 2>/dev/null
      fi
      if [[ -n "$bundle" ]]; then
        local last_session_json="${last_session:-}"
        echo "$bundle" | LAST_SESSION_JSON="$last_session_json" python3 -c "
import sys, json, os
bundle_data = sys.stdin.read()
last_session_raw = os.environ.get('LAST_SESSION_JSON', '')
try:
    b = json.loads(bundle_data)
    ops = b.get('core_operational_state', {})
    print('[V2 HYDRATED CONTEXT]')
    print(f\"  current_focus: {ops.get('current_focus') or '(none)'}\")
    ws = ops.get('active_workstreams', [])
    print(f\"  active_workstreams: {len(ws)}\")
    for w in ws[:3]:
        print(f\"    - {w.get('title','?')} ({w.get('contributor_id','?')}, {w.get('status','?')})\")
    doctrine = b.get('active_doctrine', [])
    print(f\"  active_doctrine: {len(doctrine)} canonical records\")
    for d in doctrine[:5]:
        md = d.get('metadata', {})
        print(f\"    - {md.get('path','?')}\")
    proposals = b.get('recent_context', {}).get('active_proposals', [])
    print(f\"  active_proposals: {len(proposals)}\")
    tensions = ops.get('unresolved_tensions', [])
    if tensions:
        print(f\"  unresolved_tensions: {len(tensions)}\")
        for t in tensions[:2]:
            md = t.get('metadata', {})
            print(f\"    - {md.get('path','?')}\")
    rc = b.get('recent_context', {}).get('recent_changes', '')
    if rc:
        first_entries = [l for l in rc.splitlines() if l.startswith('- **')][:3]
        if first_entries:
            print('  recent_changes (top 3):')
            for line in first_entries:
                title = line.split('**')[1] if '**' in line else line[2:80]
                print(f\"    - {title}\")
    if last_session_raw:
        try:
            ls = json.loads(last_session_raw)
            s = ls.get('last_session')
            smry = ls.get('summary')
            if s and smry:
                ended = s.get('last_active_at', '')[:16].replace('T', ' ')
                full_text = smry.get('summary', '(no summary)')
                caps = smry.get('captures_count', 0)
                print(f\"  last_session ({s.get('contributor_id','?')}, ended {ended}):\")
                for chunk in [full_text[i:i+120] for i in range(0, len(full_text), 120)]:
                    print(f\"    {chunk}\")
                if caps:
                    print(f\"    captures pending: {caps}\")
        except Exception:
            pass
except Exception as e:
    print(f'(bundle parse error: {e})')
" 2>/dev/null
      fi
      ;;
    focus)
      local focus_text="${*:-}"
      [[ -n "$focus_text" ]] || die "Usage: prismo session focus \"<what you're working on>\""
      [[ -f "$SESSION_FILE" ]] || die "No active session — run: prismo session start"
      local sid
      sid=$(cat "$SESSION_FILE")
      check_vm
      curl -sf -X PATCH "${CONTEXT_API}/workflow/context/${sid}" \
        -H 'Content-Type: application/json' \
        -d "{\"current_focus\":\"${focus_text}\"}" >/dev/null \
        && ok "Focus updated: $focus_text" \
        || die "Failed to update focus"
      ;;
    *)
      die "Unknown session subcommand: $sub (try: start, end, current, ensure, focus)"
      ;;
  esac
}

# ── stale (Decision 019 — lifecycle loop) ─────────────────────────────────────

cmd_stale() {
  local subcmd="${1:-list}"
  shift 2>/dev/null || true

  case "$subcmd" in
    list|ls|"")
      check_vm
      local project="${1:-}"
      local url="${CONTEXT_API}/stale-items"
      [[ -n "$project" ]] && url="${url}?project=${project}"
      echo ""
      curl -sf "$url" | python3 -c "
import sys, json
data = json.load(sys.stdin)
items = data.get('items', [])
if not items:
    print('  ✓ No unacknowledged stale items.')
    sys.exit(0)
print(f'  {len(items)} stale items:')
print()
for it in items:
    md = it.get('metadata', {})
    rule = it.get('rule', '?')
    iid = it['id']
    title = md.get('title') or md.get('heading', '')
    proj = md.get('doc_type', '?')
    print(f'  [{rule}]  {proj}  {title or iid[:60]}')
    print(f'             id: {iid}')
print()
print('  Ack: prismo stale ack <id> [--resolution <r>] [--note \"...\"]')
"
      ;;
    ack)
      check_vm
      local item_id="${1:-}"
      shift 2>/dev/null || true
      [[ -n "$item_id" ]] || die "Usage: prismo stale ack <item-id> [--resolution <r>] [--note '...']"
      local resolution="pending"
      local note=""
      local defer=14
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --resolution|-r) resolution="$2"; shift 2 ;;
          --note|-n) note="$2"; shift 2 ;;
          --defer|-d) defer="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done
      local payload
      payload=$(python3 -c "
import json
print(json.dumps({
  'item_id': '$item_id',
  'contributor_id': 'ethan',
  'resolution': '$resolution',
  'resolution_note': '''$note''',
  'defer_days': $defer,
}))
")
      curl -sf -X POST "${CONTEXT_API}/workflow/stale/ack" \
        -H 'Content-Type: application/json' \
        -d "$payload" | python3 -m json.tool && ok "Acknowledged: $item_id"
      ;;
    acks)
      check_vm
      curl -sf "${CONTEXT_API}/workflow/stale/acks" | python3 -m json.tool
      ;;
    *)
      die "Unknown stale subcommand: $subcmd  (try: list, ack, acks)"
      ;;
  esac
}

# ── brief (Decision 016, 018 — operational brief via service) ─────────────────

cmd_brief() {
  local project="${1:-prismo}"
  check_vm
  echo ""
  curl -sf "${CONTEXT_API}/brief?project=${project}" | python3 -c "
import sys, json
data = json.load(sys.stdin)
print(f'  {data.get(\"project\", \"?\")}  ({data.get(\"depth\", \"standard\")})')
print(f'  generated: {data.get(\"generated_at\", \"?\")}')
print()
print(data.get('brief', '(no brief returned)'))
print()
prov = data.get('provenance', {})
if prov:
    print(f'  ── synthesized via {prov.get(\"generated_by\", \"?\")}')
    print(f'  ── sources: {len(prov.get(\"source_ids\", []))} canonical records')
"
}

# ── capture (Decision 018 — operational state, not canon) ────────────────────

cmd_capture() {
  local sub="${1:-}"
  case "$sub" in
    list|ls)
      shift
      local project=""
      [[ "$#" -gt 0 && "$1" != --* ]] && { project="$1"; shift; }
      check_vm
      local url="${CONTEXT_API}/workflow/captures?status=pending-review"
      [[ -n "$project" ]] && url="${url}&project=${project}"
      curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
caps = d.get('captures', [])
if not caps:
    print('  ✓ No pending captures.')
    sys.exit(0)
print(f'  {len(caps)} pending captures:')
for c in caps:
    print(f\"  [{c['id']}]  {c['project']}  ({c['captured_at'][:16]})\")
    print(f\"           {c['text'][:120]}\")
    print()"
      ;;
    promote)
      shift
      local cid="${1:-}"
      [[ -n "$cid" ]] || die "Usage: prismo capture promote <capture_id>"
      check_vm
      # Ask the service to generate the promotion artifact (Law 3 — service owns
      # the artifact-generation logic; this CLI is a thin filesystem adapter).
      local resp
      resp=$(curl -sf -X POST "${CONTEXT_API}/workflow/capture/${cid}/promote" 2>&1) \
        || die "Promote endpoint failed: $resp"
      local project filename content
      project=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['project'])")
      filename=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['filename'])")
      content=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['content'])")
      local drafts_dir="${HOME}/canon/${project}/docs/drafts"
      [[ -d "$drafts_dir" ]] || die "Drafts dir not found: $drafts_dir"
      local file="${drafts_dir}/${filename}"
      printf '%s' "$content" > "$file"
      # Record where it landed so the workflow-state-service can link back.
      curl -sf -X PATCH "${CONTEXT_API}/workflow/capture/${cid}" \
        -H 'Content-Type: application/json' \
        -d "{\"status\":\"promoted\",\"promoted_to_path\":\"${filename}\"}" >/dev/null
      ok "Promoted ${cid} → ${file}"
      ;;
    dismiss)
      shift
      local cid="${1:-}"
      [[ -n "$cid" ]] || die "Usage: prismo capture dismiss <capture_id>"
      check_vm
      curl -sf -X PATCH "${CONTEXT_API}/workflow/capture/${cid}" \
        -H 'Content-Type: application/json' \
        -d '{"status":"dismissed"}' >/dev/null && ok "Dismissed: $cid"
      ;;
    "")
      die "Usage: prismo capture \"<text>\"  |  prismo capture list  |  prismo capture promote <id>"
      ;;
    *)
      # Default: treat all args as capture text
      local text="${*:-}"
      [[ -n "$text" ]] || die "Usage: prismo capture \"this matters because ...\""
      check_vm

      local project=""
      local cwd
      cwd=$(pwd)
      if [[ "$cwd" == "${HOME}/canon/"* ]]; then
        project=$(echo "$cwd" | sed "s|${HOME}/canon/||" | cut -d/ -f1)
      elif [[ "$cwd" == "${HOME}/projects/"* ]]; then
        project=$(echo "$cwd" | sed "s|${HOME}/projects/||" | cut -d/ -f1)
      fi
      [[ -z "$project" ]] && project="prismo"

      local session_id=""
      [[ -f "$SESSION_FILE" ]] && session_id=$(cat "$SESSION_FILE")

      local body
      body=$(python3 -c "
import json
print(json.dumps({
  'text': '''${text//\'/\\\'}''',
  'project': '$project',
  'contributor_id': 'ethan',
  'session_id': '$session_id' or None,
  'source': 'manual',
}))")
      local resp
      resp=$(curl -sf -X POST "${CONTEXT_API}/workflow/capture" \
        -H 'Content-Type: application/json' \
        -d "$body")
      local cid
      cid=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin).get('capture_id','?'))")
      ok "Captured ${cid} (project=${project}, session=${session_id:-none})"
      info "List pending: prismo capture list"
      ;;
  esac
}

# ── synth (Decision 021 — invoke synthesis-service) ───────────────────────────

cmd_synth() {
  local sub="${1:-run}"
  case "$sub" in
    run|"")
      shift 2>/dev/null || true
      local project="prismo"
      local dry_run="false"
      local max_emit=""
      local capture_ids=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p) project="$2"; shift 2 ;;
          --dry-run|-n) dry_run="true"; shift ;;
          --max-emit)   max_emit="$2"; shift 2 ;;
          --capture-ids|-c) capture_ids="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done
      check_vm
      local payload
      payload=$(python3 -c "
import json
body = {'project': '$project', 'dry_run': '$dry_run' == 'true'}
me = '$max_emit'
if me: body['max_emit'] = int(me)
ci = '$capture_ids'
if ci: body['capture_ids'] = [x.strip() for x in ci.split(',') if x.strip()]
print(json.dumps(body))")
      curl -sf -X POST "${CONTEXT_API}/synthesis/run" \
        -H 'Content-Type: application/json' \
        -d "$payload" | python3 -c "
import sys, json
d = json.load(sys.stdin)
mode = '[dry-run] ' if d.get('dry_run') else ''
print(f'')
print(f'  ── synthesis run {d[\"run_id\"]} ({mode}project={d[\"project\"]}) ──')
print(f'    captures considered: {d[\"captures_considered\"]}')
print(f'    emitted: {d[\"emitted\"]}    skipped: {d[\"skipped\"]}')
bp = d.get('backpressure', {})
if not bp.get('passed', True):
    print(f'    BACKPRESSURE: queue full ({bp.get(\"pending\")}/{bp.get(\"max\")}) — review the queue first')
if d['review_item_ids']:
    print(f'    new ReviewItems:')
    for rid in d['review_item_ids']:
        print(f'      {rid}')
if d['gate_failures']:
    print(f'    gate failures:')
    for f in d['gate_failures']:
        cap = f.get('capture_id') or '-'
        gate = f.get('gate', '?')
        reason = f.get('reason', '?')
        extras = []
        for k in ('confidence', 'threshold', 'similarity', 'max', 'pending'):
            if k in f: extras.append(f'{k}={f[k]}')
        suffix = (' (' + ', '.join(extras) + ')') if extras else ''
        print(f'      [{cap}] {gate}: {reason}{suffix}')
print(f'')
print(f'  Use: prismo review   — triage what landed')
"
      ;;
    *)
      die "Unknown synth subcommand: $sub  (try: run, run --dry-run, run --project <p>)"
      ;;
  esac
}

# ── prior-art (Decision 023 — interpretive augmentation) ─────────────────────

cmd_prior_art() {
  local description="${*:-}"
  local project="prismo"
  local no_emit="false"
  local full="false"
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project|-p) project="$2"; shift 2 ;;
      --no-emit)    no_emit="true"; shift ;;
      --full)       full="true"; shift ;;
      *) args+=("$1"); shift ;;
    esac
  done
  description="${args[*]:-}"
  [[ -n "$description" ]] || die "Usage: prismo prior-art \"description\" [--full] [--no-emit]"
  check_vm

  local emit_bool
  [[ "$no_emit" == "true" ]] && emit_bool="False" || emit_bool="True"
  local payload
  payload=$(python3 -c "
import json, sys
print(json.dumps({
  'project': '$project',
  'analysis_type': 'prior_art',
  'description': sys.argv[1],
  'emit_review_item': $emit_bool,
}))" "$description")

  echo ""
  echo "  Researching prior art... (this may take 30-60s)"
  echo ""

  curl -s --max-time 120 -X POST "${CONTEXT_API}/synthesis/analyze" \
    -H 'Content-Type: application/json' \
    -d "$payload" | python3 -c "
import sys, json
raw = sys.stdin.read()
if not raw.strip():
    print('  error: no response from server (check container logs)', file=sys.stderr)
    sys.exit(1)
d = json.loads(raw)
if 'detail' in d and 'recommendation' not in d:
    print(f'  error: {d[\"detail\"]}', file=sys.stderr)
    sys.exit(1)
full = sys.argv[1] == 'true'
print(f'  ── prior-art analysis ──')
print(f'  recommendation: {d.get(\"recommendation\", \"?\")}')
print(f'  rationale:      {d.get(\"recommendation_rationale\", \"?\")}')
print(f'  confidence:     {d.get(\"confidence\", 0):.2f}')
sources = d.get('sources', [])
if sources:
    print(f'  sources ({len(sources)}):')
    for s in sources[:5]:
        print(f'    - {s}')
    if len(sources) > 5:
        print(f'    ... and {len(sources) - 5} more')
rv = d.get('review_item_id')
if rv:
    print(f'')
    print(f'  ReviewItem: {rv}')
    print(f'  Use: prismo review show {rv}')
print(f'')
if full:
    findings = d.get('findings', '')
    if findings:
        print('  ── findings ──')
        print('')
        for line in findings.splitlines():
            print(f'  {line}')
        print('')
else:
    preview = d.get('findings_preview', '')
    if preview:
        print(f'  findings preview (--full for complete):')
        for line in preview.splitlines()[:6]:
            print(f'    {line}')
        print('')
" "$full"
}

# ── metrics (observation-week empirical surface) ──────────────────────────────

cmd_runtime() {
  local sub="${1:-topology}"
  shift || true
  check_vm
  case "$sub" in
    topology)
      curl -sf "${CONTEXT_API}/runtime/topology" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print('')
print('  ── Runtime Intelligence Topology ──')
print(f\"  observed: {d.get('observed_at','?')[:19].replace('T',' ')} UTC\")
print('')
for role_id, role in d.get('roles', {}).items():
    mode  = role.get('execution_mode', '?')
    prov  = role.get('provider', '?')
    model = role.get('model', '?')
    caps  = ', '.join(role.get('capabilities', []))
    auth  = ', '.join(role.get('authority', []))
    print(f\"  [{role_id}]\")
    print(f\"    mode:         {mode}\")
    print(f\"    provider:     {prov}\")
    print(f\"    model:        {model}\")
    print(f\"    capabilities: {caps}\")
    print(f\"    authority:    {auth}\")
    print('')
" 2>/dev/null || die "Failed to fetch runtime topology"
      ;;
    role)
      local role_id="${1:-}"
      [[ -n "$role_id" ]] || die "Usage: prismo runtime role <role_id>"
      curl -sf "${CONTEXT_API}/runtime/roles/${role_id}" | python3 -m json.tool \
        || die "Role not found: ${role_id}"
      ;;
    *)
      die "Unknown runtime subcommand: $sub (try: topology, role <id>)"
      ;;
  esac
}

cmd_metrics() {
  local project=""
  local since=7
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project|-p) project="$2"; shift 2 ;;
      --since|--days|-d) since="$2"; shift 2 ;;
      *) die "Unknown flag: $1" ;;
    esac
  done
  check_vm
  local url="${CONTEXT_API}/workflow/metrics?since_days=${since}"
  [[ -n "$project" ]] && url="${url}&project=${project}"
  curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
rv = d['review_items']
cap = d['captures']
def fmt(v, suffix=''):
    return f'{v}{suffix}' if v is not None else '—'
def pct(v):
    return f'{v*100:.1f}%' if v is not None else '—'

print(f'')
print(f'  ── ReviewItems ({rv[\"window_days\"]}d window) ──')
print(f'    total: {rv[\"total\"]}    pending: {rv[\"pending\"]}    decided: {rv[\"decided_total\"]}')
print(f'    approval rate: {pct(rv[\"approval_rate\"])}    edit rate of approvals: {pct(rv[\"edit_rate\"])}')
if rv['status_distribution']:
    print(f'    status: ' + ', '.join(f'{k}={v}' for k, v in sorted(rv['status_distribution'].items())))
if rv['rejection_reason_distribution']:
    print(f'    rejections by reason: ' + ', '.join(f'{k}={v}' for k, v in sorted(rv['rejection_reason_distribution'].items())))
mc = rv['mean_confidence_by_outcome']
if any(mc.values()):
    parts = []
    for k in ('approved', 'edited-approved', 'rejected'):
        if mc.get(k) is not None:
            parts.append(f'{k}={mc[k]:.2f}')
    if parts:
        print(f'    mean confidence: ' + ', '.join(parts))
ttd = rv['time_to_decision_seconds']
if ttd['count'] > 0:
    def hms(s):
        if s is None: return '—'
        h, rem = divmod(s, 3600); m, sec = divmod(rem, 60)
        if h >= 1: return f'{h:.0f}h{m:.0f}m'
        if m >= 1: return f'{m:.0f}m{sec:.0f}s'
        return f'{sec:.0f}s'
    print(f'    time-to-decision: p50={hms(ttd[\"p50\"])}, p90={hms(ttd[\"p90\"])}, max={hms(ttd[\"max\"])} (n={ttd[\"count\"]})')
print(f'')
print(f'  ── Captures ({cap[\"window_days\"]}d window) ──')
print(f'    total: {cap[\"total\"]}    pending: {cap[\"pending_review\"]}    promoted: {cap[\"promoted\"]}    dismissed: {cap[\"dismissed\"]}')
print(f'    promotion rate: {pct(cap[\"promotion_rate\"])}')
print(f'')
print(f'  Filters: project={d[\"project\"] or \"(all)\"}, since={rv[\"window_days\"]}d')
print(f'  Use --project <name> or --since <days> to narrow.')
"
}

# ── review (Decision 021 — human-judgment boundary) ───────────────────────────

cmd_review() {
  local sub="${1:-list}"
  case "$sub" in
    list|ls|"")
      shift 2>/dev/null || true
      local project=""
      local status="pending"
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --project|-p) project="$2"; shift 2 ;;
          --status|-s)  status="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done
      check_vm
      local url="${CONTEXT_API}/review/queue?status=${status}"
      [[ -n "$project" ]] && url="${url}&project=${project}"
      curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
items = d.get('items', [])
if not items:
    print(f'  ✓ No {d[\"status_filter\"]} ReviewItems.')
    sys.exit(0)
print(f'  {len(items)} {d[\"status_filter\"]} ReviewItem(s):')
print()
for it in items:
    p = it['proposal']
    print(f'  [{it[\"id\"]}]  {p[\"artifact_type\"]:<18} confidence={it[\"confidence\"]:.2f}')
    print(f'    {p[\"suggested_destination\"] or \"(no destination)\"}')
    print(f'    rationale: {it[\"rationale\"][:120]}{\"...\" if len(it[\"rationale\"])>120 else \"\"}')
    src = it.get('sources', {})
    if src.get('capture_ids'):
        print(f'    sources: captures={src[\"capture_ids\"]}')
    print()
print('  prismo review show <id>       — full proposal')
print('  prismo review approve <id>    — write canon + commit + reindex')
print('  prismo review reject <id> -r <reason> [-n \"note\"]')
print('  prismo review edit <id>       — open in \$EDITOR')
"
      ;;
    show)
      shift
      local item_id="${1:-}"
      [[ -n "$item_id" ]] || die "Usage: prismo review show <id>"
      check_vm
      local raw
      raw=$(curl -sf "${CONTEXT_API}/review/queue/${item_id}" 2>/dev/null) \
        || die "ReviewItem '${item_id}' not found"
      [[ -n "$raw" ]] || die "ReviewItem '${item_id}' not found"
      echo "$raw" | python3 -c "
import sys, json
d = json.load(sys.stdin)
p = d['proposal']
print(f'─── {d[\"id\"]} ─── {p[\"artifact_type\"]} — confidence {d[\"confidence\"]:.2f} ───')
print(f'project:  {d[\"project\"]}')
print(f'status:   {d[\"status\"]}')
print(f'created:  {d[\"created_at\"]}')
print(f'dest:     {p[\"suggested_destination\"]}')
print(f'model:    {d[\"model_used\"]} | prompt: {d[\"prompt_template_id\"]}')
print()
print('SOURCES:')
print(json.dumps(d['sources'], indent=2))
print()
print('FRONTMATTER:')
print(json.dumps(p.get('frontmatter', {}), indent=2))
print()
print('AFFECTED EXISTING DOCS:', p.get('affected_existing_docs') or '(none)')
print()
print('RATIONALE:')
print(d['rationale'])
print()
print('═══ PROPOSAL CONTENT ═══')
print(p['content'])
print('═══ END ═══')
"
      ;;
    approve|a)
      shift
      local item_id="${1:-}"
      [[ -n "$item_id" ]] || die "Usage: prismo review approve <id>"
      check_vm

      # Approve transitions state + returns payload; we write the file locally
      # since /canon is read-only in the api container (Law 3 — adapter writes).
      local resp project dest content target_path canon_root
      resp=$(curl -sf -X POST "${CONTEXT_API}/review/queue/${item_id}/approve" \
        -H 'Content-Type: application/json' -d '{"decided_by":"ethan"}' 2>&1) \
        || die "Approve endpoint failed: $resp"

      project=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['project'])")
      dest=$(echo "$resp"    | python3 -c "import sys,json; print(json.load(sys.stdin)['proposal']['suggested_destination'])")
      content=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['proposal']['content'])")

      [[ -n "$dest" ]] || die "Approved item has empty suggested_destination — manual placement required"
      canon_root="${HOME}/canon/${project}"
      [[ -d "$canon_root" ]] || die "Canon repo not found: $canon_root"
      target_path="${canon_root}/docs/${dest}"

      if [[ -e "$target_path" ]]; then
        echo -e "${YELLOW}!${NC} Target exists: $target_path"
        read -r -p "  Overwrite? [y/N] " ans
        [[ "$ans" =~ ^[Yy]$ ]] || die "Aborted (file exists)"
      fi

      mkdir -p "$(dirname "$target_path")"
      printf '%s' "$content" > "$target_path"
      ok "Wrote ${target_path}"

      (cd "$canon_root" && git pull --ff-only >/dev/null 2>&1 || true) || true
      (cd "$canon_root" \
        && git add "docs/${dest}" \
        && git commit -m "${item_id}: ${dest} (approved via prismo review)

Approved ReviewItem ${item_id} from synthesis-service.
" \
        && git push) || die "git commit/push failed in $canon_root"
      ok "Committed + pushed in $canon_root"

      curl -sf -X POST "${CONTEXT_API}/index" >/dev/null && ok "Re-indexed"
      ;;
    reject|r)
      shift
      local item_id="${1:-}"
      shift 2>/dev/null || true
      [[ -n "$item_id" ]] || die "Usage: prismo review reject <id> -r <reason> [-n 'note']"
      local reason="" note=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --reason|-r) reason="$2"; shift 2 ;;
          --note|-n)   note="$2"; shift 2 ;;
          *) die "Unknown flag: $1" ;;
        esac
      done
      [[ -n "$reason" ]] || die "Reason required. Use one of: redundant, too-weak, already-represented, incorrect-interpretation, wrong-artifact-type, too-speculative, not-durable, other"
      check_vm
      local payload
      payload=$(python3 -c "
import json
print(json.dumps({
  'decided_by': 'ethan',
  'rejection_reason': '$reason',
  'rejection_note': '''$note''' or None,
}))")
      curl -sf -X POST "${CONTEXT_API}/review/queue/${item_id}/reject" \
        -H 'Content-Type: application/json' -d "$payload" >/dev/null \
        && ok "Rejected ${item_id} (${reason})"
      ;;
    edit|e)
      shift
      local item_id="${1:-}"
      [[ -n "$item_id" ]] || die "Usage: prismo review edit <id>"
      check_vm
      local editor="${EDITOR:-vi}"
      local tmpf
      tmpf=$(mktemp --suffix=.md)
      curl -sf "${CONTEXT_API}/review/queue/${item_id}" \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['proposal']['content'])" > "$tmpf"
      local before_hash
      before_hash=$(md5sum "$tmpf" | awk '{print $1}')
      "$editor" "$tmpf"
      local after_hash
      after_hash=$(md5sum "$tmpf" | awk '{print $1}')
      if [[ "$before_hash" == "$after_hash" ]]; then
        rm -f "$tmpf"
        die "No changes made — aborting (use 'prismo review approve' if you accept as-is)"
      fi

      # Submit edit → returns the now-edited-approved proposal payload
      local edited_payload resp project dest content target_path canon_root
      edited_payload=$(python3 -c "
import json
with open('$tmpf') as f: content = f.read()
print(json.dumps({'decided_by': 'ethan', 'content': content}))")
      resp=$(curl -sf -X POST "${CONTEXT_API}/review/queue/${item_id}/edit" \
        -H 'Content-Type: application/json' -d "$edited_payload" 2>&1) \
        || { rm -f "$tmpf"; die "Edit endpoint failed: $resp"; }
      rm -f "$tmpf"

      # Same write-commit-reindex pattern as approve
      project=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['project'])")
      dest=$(echo "$resp"    | python3 -c "import sys,json; print(json.load(sys.stdin)['proposal']['suggested_destination'])")
      content=$(echo "$resp" | python3 -c "import sys,json; print(json.load(sys.stdin)['proposal']['content'])")

      [[ -n "$dest" ]] || die "Edited item has empty suggested_destination — manual placement required"
      canon_root="${HOME}/canon/${project}"
      [[ -d "$canon_root" ]] || die "Canon repo not found: $canon_root"
      target_path="${canon_root}/docs/${dest}"

      if [[ -e "$target_path" ]]; then
        echo -e "${YELLOW}!${NC} Target exists: $target_path"
        read -r -p "  Overwrite? [y/N] " ans
        [[ "$ans" =~ ^[Yy]$ ]] || die "Aborted (file exists)"
      fi

      mkdir -p "$(dirname "$target_path")"
      printf '%s' "$content" > "$target_path"
      ok "Wrote (edited) ${target_path}"
      (cd "$canon_root" && git pull --ff-only >/dev/null 2>&1 || true) || true
      (cd "$canon_root" \
        && git add "docs/${dest}" \
        && git commit -m "${item_id}: ${dest} (edited + approved via prismo review)

Edited and approved ReviewItem ${item_id} from synthesis-service.
" \
        && git push) || die "git commit/push failed in $canon_root"
      ok "Committed + pushed in $canon_root"
      curl -sf -X POST "${CONTEXT_API}/index" >/dev/null && ok "Re-indexed"
      ;;
    *)
      die "Unknown review subcommand: $sub  (try: list, show, approve, reject, edit)"
      ;;
  esac
}

# ── pipeline (Decision 026 — Layer 3.5 activation) ───────────────────────────

_KNOWN_FACETS="architect assess migrate sukuna review deploy onboard wrap-up"

# _extract_prompt: read UserPromptSubmit hook JSON from stdin, return prompt text
_pipeline_extract_prompt() {
  python3 -c "
import sys, json
data = sys.stdin.read()
try:
    obj = json.loads(data)
    text = obj.get('prompt') or obj.get('user_prompt') or ''
except Exception:
    text = data
text = text.strip()
if text.startswith('<'):
    text = ''
print(text[:400])
" 2>/dev/null
}

# _format_facet_bundle: render a PipelineResult bundle as a [FACET] or [SEQUENCE] system block
_format_facet_bundle() {
  local activation_id="$1"
  local score="$2"
  local activation_mode="$3"   # "explicit" or "auto"
  local bundle_json="$4"

  python3 -c "
import json, sys

activation_id = sys.argv[1]
score = sys.argv[2]
mode = sys.argv[3]
bundle_raw = sys.argv[4]

try:
    result = json.loads(bundle_raw)
    bundle = result.get('bundle', {})
    entry = bundle.get(activation_id, {})
    activation_type = entry.get('type', 'facet')
    context = entry.get('context', {})
    heuristics = entry.get('heuristics', '').strip()
    steps = entry.get('steps', [])
except Exception as e:
    print(f'[FACET: {activation_id} | parse error: {e}]')
    sys.exit(0)

score_str = f'score: {score}' if mode == 'auto' else 'explicit'
label = 'SEQUENCE' if activation_type == 'sequence' else 'FACET'
print(f'[{label}: {activation_id} | {score_str}]')

if activation_type == 'sequence' and steps:
    # SEQUENCE: numbered step list
    print()
    print(f'Steps ({len(steps)}):')
    for i, step in enumerate(steps, 1):
        step_label = step.get('label', step.get('id', f'step-{i}'))
        detail = step.get('detail', '')
        req = ' *' if step.get('required') else ''
        print(f'  {i}. {step_label}{req}')
        if detail:
            print(f'     {detail}')
else:
    # FACET: free-form reasoning posture
    if heuristics:
        print()
        print('Reasoning posture:')
        for line in heuristics.splitlines():
            print(f'  {line}')

# Summary of loaded context
loaded = list(context.keys())
if loaded:
    print()
    print(f'Context loaded ({len(loaded)} sources): {chr(44).join(loaded)}')

# Governing doctrine — titles only
doctrine = context.get('governing_doctrine', [])
if doctrine:
    print()
    print(f'Governing doctrine ({len(doctrine)} decisions):')
    seen = set()
    for item in doctrine[:6]:
        path = item.get('metadata', {}).get('path', '')
        if path and path not in seen:
            seen.add(path)
            name = path.split('/')[-1].replace('.md', '')
            print(f'  - {name}')

# Recent changes — first 3 entries
rc = context.get('recent_changes', '')
if rc:
    entries = [l for l in rc.splitlines() if l.startswith('- **')][:3]
    if entries:
        print()
        print('Recent changes:')
        for e in entries:
            title = e.split('**')[1] if '**' in e else e[2:80]
            print(f'  - {title}')

# Topology summary
topology = context.get('topology', {})
if topology:
    roles = topology.get('roles', {})
    if roles:
        print()
        print(f'Runtime topology: {len(roles)} roles ({chr(44).join(list(roles.keys())[:3])}...)')

print()
" "$activation_id" "$score" "$activation_mode" "$bundle_json" 2>/dev/null
}

cmd_pipeline() {
  local subcmd="${1:-help}"
  shift 2>/dev/null || true

  case "$subcmd" in
    process)
      # Called by UserPromptSubmit hook on every prompt.
      # Reads hook JSON from stdin, routes to activations, emits [FACET] blocks.
      # Fails silently — never blocks a prompt.
      local prompt=""
      if [[ ! -t 0 ]]; then
        prompt=$(_pipeline_extract_prompt)
      else
        prompt="${*:-}"
      fi
      [[ -n "$prompt" ]] || return 0

      # Detect explicit facet invocation (e.g. /architect some question)
      local explicit_facet=""
      for facet in $_KNOWN_FACETS; do
        if echo "$prompt" | grep -qiE "^/${facet}( |$)"; then
          explicit_facet="$facet"
          break
        fi
      done

      if [[ -n "$explicit_facet" ]]; then
        # Explicit: full assembly via /pipeline/activate
        local args
        args=$(echo "$prompt" | sed -E "s|^/[^ ]+ *||")
        local result
        result=$(curl -sf --max-time 15 -X POST "${CONTEXT_API}/pipeline/activate" \
          -H 'Content-Type: application/json' \
          -d "$(python3 -c "import json,sys; print(json.dumps({'activation_id':'${explicit_facet}','args':sys.argv[1]}))" "$args")" 2>/dev/null)
        [[ -n "$result" ]] || return 0
        echo ""
        _format_facet_bundle "$explicit_facet" "1.0" "explicit" "$result"
      else
        # Automatic: route via /pipeline/process
        local result
        result=$(curl -sf --max-time 10 -X POST "${CONTEXT_API}/pipeline/process" \
          -H 'Content-Type: application/json' \
          -d "$(python3 -c "import json,sys; print(json.dumps({'message':sys.argv[1],'policy':{'min_score':0.72}}))" "$prompt")" 2>/dev/null)
        [[ -n "$result" ]] || return 0

        local activation_count
        activation_count=$(echo "$result" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    print(len(d.get('activations', [])))
except Exception:
    print(0)" 2>/dev/null)
        [[ "${activation_count:-0}" -gt 0 ]] || return 0

        echo ""
        echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
for match in d.get('activations', []):
    print(match['activation_id'], match['score'])
" 2>/dev/null | while IFS=' ' read -r aid score; do
          [[ -n "$aid" ]] || continue
          _format_facet_bundle "$aid" "$score" "auto" "$result"
        done
      fi
      ;;

    activate)
      # Direct activation: prismo pipeline activate <facet> [args...]
      local facet_id="${1:-}"
      shift 2>/dev/null || true
      [[ -n "$facet_id" ]] || { echo "Usage: prismo pipeline activate <facet-id> [args]"; return 1; }
      local args="${*:-}"
      local result
      result=$(curl -sf --max-time 15 -X POST "${CONTEXT_API}/pipeline/activate" \
        -H 'Content-Type: application/json' \
        -d "$(python3 -c "import json,sys; print(json.dumps({'activation_id':sys.argv[1],'args':sys.argv[2]}))" "$facet_id" "$args")" 2>/dev/null)
      if [[ -z "$result" ]]; then
        warn "pipeline activate: no response from context-server (is it running?)"
        return 1
      fi
      _format_facet_bundle "$facet_id" "1.0" "explicit" "$result"
      ;;

    list)
      # List registered activations
      curl -sf "${CONTEXT_API}/pipeline/activations" 2>/dev/null \
        | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f\"{d['count']} registered activation(s):\")
for a in d.get('activations', []):
    print(f\"  {a['id']} [{a['type']}] threshold={a['threshold']} keywords={a['keywords'][:3]}\")" 2>/dev/null \
        || die "pipeline list: could not reach context-server"
      ;;

    process-response)
      # Called by Phase 5 adapters (WhatsApp, web UI) after receiving model output.
      # Reads response text from stdin or args, POSTs to /pipeline/process-response.
      local response_text=""
      if [[ ! -t 0 ]]; then
        response_text=$(cat 2>/dev/null)
      else
        response_text="${*:-}"
      fi
      [[ -n "$response_text" ]] || return 0
      local project="${PRISMO_PROJECT:-prismo}"
      local result
      result=$(curl -sf --max-time 10 -X POST "${CONTEXT_API}/pipeline/process-response" \
        -H 'Content-Type: application/json' \
        -d "$(python3 -c "import json,sys; print(json.dumps({'response':sys.argv[1],'project':'${project}'}))" "$response_text")" 2>/dev/null)
      [[ -n "$result" ]] || return 0
      echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
n = d.get('captures_created', 0)
if n > 0:
    print(f'[PIPELINE] {n} capture(s) auto-created from response')
    for c in d.get('captures', []):
        print(f\"  [{c['id']}] {c['text'][:80]}\")" 2>/dev/null
      ;;

    capture-response)
      # Called by the Claude Code Stop hook (Decision 028, Phase 5).
      # Reads Stop hook JSON from stdin ({session_id, transcript_path, ...}),
      # extracts the last assistant text from the transcript, and pipes it
      # to /pipeline/process-response. Fails silently — never blocks.
      if [[ -t 0 ]]; then return 0; fi
      local raw
      raw=$(cat 2>/dev/null)
      [[ -n "$raw" ]] || return 0

      local transcript_path project session_id
      transcript_path=$(echo "$raw" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
    print(d.get('transcript_path') or '')
except Exception:
    print('')" 2>/dev/null)
      session_id=$(echo "$raw" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
    print(d.get('session_id') or '')
except Exception:
    print('')" 2>/dev/null)
      [[ -n "$transcript_path" && -f "$transcript_path" ]] || return 0

      # Extract the last assistant text response from the JSONL transcript.
      # Skips thinking-only turns and turns with no text content.
      local response_text
      response_text=$(python3 -c "
import json, sys

path = sys.argv[1]
min_len = 80  # ignore very short responses (tool summaries, one-liners)

last_text = ''
with open(path) as f:
    for line in f:
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except Exception:
            continue
        if entry.get('type') != 'assistant':
            continue
        content = entry.get('message', {}).get('content', [])
        text_blocks = [c.get('text', '') for c in content if c.get('type') == 'text']
        combined = ' '.join(text_blocks).strip()
        if len(combined) >= min_len:
            last_text = combined

print(last_text)
" "$transcript_path" 2>/dev/null)

      [[ -n "$response_text" ]] || return 0

      local project="${PRISMO_PROJECT:-prismo}"
      local result
      result=$(curl -sf --max-time 10 -X POST "${CONTEXT_API}/pipeline/process-response" \
        -H 'Content-Type: application/json' \
        -d "$(python3 -c "
import json, sys
print(json.dumps({'response': sys.argv[1], 'project': sys.argv[2]}))" \
          "$response_text" "$project")" 2>/dev/null)
      [[ -n "$result" ]] || return 0
      echo "$result" | python3 -c "
import sys, json
d = json.load(sys.stdin)
n = d.get('captures_created', 0)
if n > 0:
    print(f'[PIPELINE] {n} capture(s) auto-created from response')
    for c in d.get('captures', []):
        print(f\"  [{c['id']}] {c['text'][:80]}\")" 2>/dev/null
      ;;

    *)
      echo "Usage: prismo pipeline process|activate|capture-response|process-response|list"
      echo "  process              — route current prompt and emit matching [FACET] blocks (hook use)"
      echo "  activate <id> [args] — directly activate a named facet"
      echo "  capture-response     — Stop hook: extract last assistant text from transcript, auto-capture (Decision 028)"
      echo "  process-response     — run model output through response processor (Phase 5 adapters)"
      echo "  list                 — list registered activations"
      ;;
  esac
}

# ── doctrine (Decision 020 — structural coherence) ───────────────────────────

cmd_doctrine() {
  local sub="${1:-help}"
  shift 2>/dev/null || true

  # Common optional --project flag parser
  _parse_project() {
    local project=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --project|-p) project="$2"; shift 2 ;;
        *) shift ;;
      esac
    done
    echo "$project"
  }

  check_vm

  case "$sub" in
    validate)
      local project
      project=$(_parse_project "$@")
      local url="${CONTEXT_API}/doctrine/validate"
      [[ -n "$project" ]] && url="${url}?project=${project}"
      curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
proj = d.get('project') or '(all)'
print(f'  doctrine validate — {proj}')
print(f'  checked: {d[\"checked\"]}    violations: {d[\"violation_count\"]}')
if not d['violations']:
    print('  ✓ Canon is structurally clean.')
else:
    print()
    for v in d['violations']:
        print(f'  [{v[\"rule\"]}]  {v[\"path\"]}')
        print(f'     {v[\"detail\"]}')
"
      ;;
    supersession)
      local project
      project=$(_parse_project "$@")
      local url="${CONTEXT_API}/doctrine/supersession"
      [[ -n "$project" ]] && url="${url}?project=${project}"
      curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
proj = d.get('project') or '(all)'
print(f'  doctrine supersession — {proj}')
print(f'  superseded docs: {d[\"superseded_count\"]}    chain violations: {d[\"violation_count\"]}')
if not d['violations']:
    print('  ✓ All supersession chains are intact.')
else:
    print()
    for v in d['violations']:
        print(f'  [{v[\"rule\"]}]  {v[\"path\"]}')
        print(f'     {v[\"detail\"]}')
"
      ;;
    provenance)
      local project
      project=$(_parse_project "$@")
      local url="${CONTEXT_API}/doctrine/provenance"
      [[ -n "$project" ]] && url="${url}?project=${project}"
      curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
proj = d.get('project') or '(all)'
print(f'  doctrine provenance — {proj}')
print(f'  synthesized records: {d[\"synthesized_count\"]}    violations: {d[\"violation_count\"]}')
if not d['violations']:
    print('  ✓ All synthesized records carry required provenance.')
else:
    print()
    for v in d['violations']:
        print(f'  [{v[\"rule\"]}]  {v[\"path\"]}')
        print(f'     {v[\"detail\"]}')
"
      ;;
    relationships)
      local path_arg="${1:-}"
      shift 2>/dev/null || true
      [[ -n "$path_arg" ]] || die "Usage: prismo doctrine relationships <path> [--project <p>]"
      local project
      project=$(_parse_project "$@")
      local url="${CONTEXT_API}/doctrine/relationships?path=${path_arg}"
      [[ -n "$project" ]] && url="${url}&project=${project}"
      curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if not d.get('found'):
    print(f'  ✗ Not found: {d[\"path\"]}')
    sys.exit(1)
print(f'  {d[\"path\"]}  [{d.get(\"status\",\"?\")}]')
up = d.get('upstream', [])
down = d.get('downstream', [])
if up:
    print(f'  supersedes ({len(up)}):')
    for r in up:
        print(f'    → {r[\"path\"]}  [{r[\"status\"]}]')
else:
    print('  supersedes: (none)')
if down:
    print(f'  superseded by this ({len(down)}):')
    for r in down:
        print(f'    ← {r[\"path\"]}  [{r[\"status\"]}]')
else:
    print('  superseded by this: (none)')
"
      ;;
    graph)
      local project
      project=$(_parse_project "$@")
      local url="${CONTEXT_API}/doctrine/graph"
      [[ -n "$project" ]] && url="${url}?project=${project}"
      curl -sf "$url" | python3 -c "
import sys, json
d = json.load(sys.stdin)
proj = d.get('project') or '(all)'
print(f'  doctrine graph — {proj}')
print(f'  nodes: {d[\"node_count\"]}    edges: {d[\"edge_count\"]}')
if d['edges']:
    print()
    print('  Supersession edges:')
    for e in d['edges']:
        print(f'    {e[\"from\"]}')
        print(f'      → {e[\"to\"]}')
"
      ;;
    *)
      echo "Usage: prismo doctrine <subcommand> [--project <p>]"
      echo ""
      echo "  validate                    — structural metadata linting (missing/invalid fields)"
      echo "  supersession                — supersession chain integrity (broken pointers)"
      echo "  provenance                  — Decision 018 provenance on synthesized records"
      echo "  relationships <path>        — upstream/downstream graph for a single doc"
      echo "  graph                       — full supersession graph (all nodes + edges)"
      echo ""
      echo "All subcommands accept --project <name> to scope to one project."
      ;;
  esac
}

# ── help ──────────────────────────────────────────────────────────────────────

cmd_help() {
  echo ""
  echo -e "${BOLD}prismo${NC} — Prismo project automation"
  echo ""
  echo -e "  ${BOLD}new-machine${NC}                      Set up this machine for Prismo"
  echo -e "  ${BOLD}new-project${NC} <name> <repo-url>   Add a new project end-to-end"
  echo -e "  ${BOLD}index${NC} [<project>]               Re-index docs (or code for a project)"
  echo -e "  ${BOLD}status${NC}                          Check VM connectivity and hook health"
  echo -e "  ${BOLD}session${NC} [start|end|current|focus] Workflow-state-service — Decisions 014, 016"
  echo -e "  ${BOLD}stale${NC} [list|ack|acks]           Lifecycle inbox — Decision 019"
  echo -e "  ${BOLD}brief${NC} [<project>]               Generate operational brief — Decisions 016, 018"
  echo -e "  ${BOLD}capture${NC} \"<text>\"                 Capture a signal candidate (operational state, Decision 018)"
  echo -e "  ${BOLD}review${NC}  [list|show|approve|reject|edit]  Human-judgment boundary inbox — Decision 021"
  echo -e "  ${BOLD}synth${NC}      run [--dry-run] [--project <p>]  Trigger synthesis-service over pending captures"
  echo -e "  ${BOLD}prior-art${NC} \"<desc>\" [--full] [--no-emit]     Research prior art; --full prints complete findings"
  echo -e "  ${BOLD}metrics${NC}   [--project <p>] [--since <days>]  Observation-week empirical dashboard"
  echo -e "  ${BOLD}pipeline${NC}  process|activate|process-response|list  Layer 3.5 — Decisions 026/028"
  echo -e "  ${BOLD}doctrine${NC}  validate|supersession|provenance|relationships|graph  Structural coherence — Decision 020"
  echo ""
  echo "Examples:"
  echo "  prismo new-machine"
  echo "  prismo new-project myapp git@github.com:you/myapp.git"
  echo "  prismo index"
  echo "  prismo status"
  echo "  prismo stale"
  echo "  prismo stale ack prismo/proposed-ideas/002.md --resolution resolved"
  echo "  prismo brief prismo"
  echo "  prismo capture \"the brief endpoint needs caching\""
  echo "  prismo review                          # list pending"
  echo "  prismo review show rv_abc123"
  echo "  prismo review approve rv_abc123        # writes canon + commits + reindexes"
  echo "  prismo review reject rv_abc123 -r too-weak -n \"needs more evidence\""
  echo "  prismo review edit rv_abc123           # opens \$EDITOR, then writes + commits"
  echo ""
  echo "Bootstrap a new machine (two commands):"
  echo "  git clone git@github.com:EthanPlusPlus/prismo.git ~/canon/prismo"
  echo "  ~/canon/prismo/scripts/prismo new-machine"
}

# ── dispatch ──────────────────────────────────────────────────────────────────

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
  new-machine)    cmd_new_machine ;;
  new-project)    cmd_new_project "$@" ;;
  index)          cmd_index "$@" ;;
  status)         cmd_status ;;
  session)        cmd_session "$@" ;;
  stale)          cmd_stale "$@" ;;
  brief)          cmd_brief "$@" ;;
  capture)        cmd_capture "$@" ;;
  review)         cmd_review "$@" ;;
  synth)          cmd_synth "$@" ;;
  prior-art)      cmd_prior_art "$@" ;;
  runtime)        cmd_runtime "$@" ;;
  metrics)        cmd_metrics "$@" ;;
  pipeline)       cmd_pipeline "$@" ;;
  doctrine)       cmd_doctrine "$@" ;;
  help|--help|-h) cmd_help ;;
  *) die "Unknown command: $CMD  (run 'prismo help')" ;;
esac
